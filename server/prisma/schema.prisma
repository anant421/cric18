// ScoreXI - Prisma schema
// PostgreSQL datasource (works locally against a local Postgres, or a hosted
// instance like Neon, via DATABASE_URL). Enum-like fields are plain Strings
// validated in application code (see src/routes and src/scoring.js) rather
// than native Postgres enums, so this schema is easy to point at any SQL
// database without extra type work.
// Valid values:
//   PlayerRole:   BATSMAN | BOWLER | ALLROUNDER | WICKETKEEPER
//   MatchStatus:  SCHEDULED | LIVE | COMPLETED | ABANDONED
//   TossDecision: BAT | BOWL
//   ExtraType:    NONE | WIDE | NOBALL | BYE | LEGBYE
//   WicketType:   BOWLED | CAUGHT | LBW | RUNOUT | STUMPED | HITWICKET | RETIRED_OUT | RETIRED_HURT
//   MatchStage:   LEAGUE | FINAL
//   Gender:       MALE | FEMALE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  season    String?
  createdAt DateTime @default(now())

  // Admin-designated highlight - which specific catch (by ball) was the
  // best of the tournament. Unlike the other awards this can't be derived
  // from stats alone, so it's a manual pick from among all catches taken.
  bestCatchBallId String? @unique
  bestCatchBall   Ball?   @relation("BestCatchOfTournament", fields: [bestCatchBallId], references: [id], onDelete: SetNull)

  teams   Team[]
  players Player[]
  matches Match[]
}

model Team {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  shortName    String
  colorHex     String     @default("#1d9bf0")
  logoUrl      String?
  createdAt    DateTime   @default(now())

  players       Player[]
  homeMatches   Match[] @relation("TeamA")
  awayMatches   Match[] @relation("TeamB")
  tossWinsAsRef Match[] @relation("TossWinner")
  wonMatches    Match[] @relation("WinnerTeam")
}

model Player {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name         String
  role         String     @default("BATSMAN")
  gender       String?
  battingStyle String?
  bowlingStyle String?
  photoUrl     String?
  // Globally unique so the same person can't register twice across any
  // tournament - the app-layer duplicate check relies on this constraint.
  mobileNumber String?    @unique
  createdAt    DateTime   @default(now())

  ballsAsStriker    Ball[]  @relation("Striker")
  ballsAsNonStriker Ball[]  @relation("NonStriker")
  ballsAsBowler     Ball[]  @relation("Bowler")
  ballsAsDismissed  Ball[]  @relation("Dismissed")
  ballsAsFielder    Ball[]  @relation("Fielder")
  manOfMatchAwards  Match[] @relation("ManOfMatch")
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamAId      String
  teamA        Team       @relation("TeamA", fields: [teamAId], references: [id], onDelete: Cascade)
  teamBId      String
  teamB        Team       @relation("TeamB", fields: [teamBId], references: [id], onDelete: Cascade)
  oversLimit   Int        @default(8)
  venue        String?
  scheduledAt  DateTime?
  status       String     @default("SCHEDULED")
  stage        String     @default("LEAGUE")

  manOfMatchId String?
  manOfMatch   Player? @relation("ManOfMatch", fields: [manOfMatchId], references: [id], onDelete: SetNull)

  tossWinnerTeamId String?
  tossWinnerTeam    Team?   @relation("TossWinner", fields: [tossWinnerTeamId], references: [id], onDelete: Cascade)
  tossDecision      String?
  umpire1           String?
  umpire2           String?

  currentInningsNumber Int @default(0)

  winnerTeamId String?
  winnerTeam   Team?   @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: Cascade)
  resultText   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  innings Innings[]
}

model Innings {
  id            String  @id @default(cuid())
  matchId       String
  match         Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  inningsNumber Int
  battingTeamId String
  bowlingTeamId String
  target        Int?
  isCompleted   Boolean @default(false)

  openingStrikerId    String?
  openingNonStrikerId String?
  openingBowlerId     String?

  createdAt DateTime @default(now())

  balls Ball[]
}

model Ball {
  id         String  @id @default(cuid())
  inningsId  String
  innings    Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  sequence   Int
  overNumber Int
  ballInOver Int
  isLegal    Boolean

  strikerId    String
  striker      Player @relation("Striker", fields: [strikerId], references: [id], onDelete: Cascade)
  nonStrikerId String
  nonStriker   Player @relation("NonStriker", fields: [nonStrikerId], references: [id], onDelete: Cascade)
  bowlerId     String
  bowler       Player @relation("Bowler", fields: [bowlerId], references: [id], onDelete: Cascade)

  runsBat     Int     @default(0)
  extraType   String  @default("NONE")
  extraRuns   Int     @default(0)
  // Runs taken off a fielding-error overthrow, already included in runsBat
  // (they count fully toward the batter per the Laws) - this flag is purely
  // so the UI can show e.g. "7ot" instead of a plain "7".
  isOverthrow Boolean @default(false)

  isWicket    Boolean @default(false)
  wicketType  String?
  dismissedId String?
  dismissed   Player? @relation("Dismissed", fields: [dismissedId], references: [id], onDelete: Cascade)
  fielderId   String?
  fielder     Player? @relation("Fielder", fields: [fielderId], references: [id], onDelete: Cascade)

  // Marks this ball as excluded from the innings' over-budget entirely - the
  // whole over it belonged to is voided (e.g. a bowler barred mid-over for
  // an illegal action). Runs/wickets/individual batting and bowling figures
  // still count exactly as recorded; only the "how many overs has this
  // innings used" tally skips these balls, so a new bowler restarts the
  // same over number from ball 1 with the innings' overs budget untouched.
  voidedFromOver Boolean @default(false)

  isFreeHit Boolean  @default(false)
  createdAt DateTime @default(now())

  bestCatchOfTournament Tournament? @relation("BestCatchOfTournament")

  @@index([inningsId, sequence])
}
